{
  "dashboard": {
    "id": null,
    "uid": "observeall-microservices",
    "title": "ObserveAll — Microservices Overview",
    "tags": ["observeall", "microservices"],
    "timezone": "browser",
    "schemaVersion": 38,
    "refresh": "10s",
    "panels": [
      {
        "type": "row",
        "title": "Order Service",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
        "collapsed": false,
        "id": 100
      },
      {
        "type": "stat",
        "title": "Request Rate",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
        "id": 1,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]}
          }
        },
        "targets": [{
          "expr": "sum(rate(order_requests_total[1m]))",
          "legendFormat": "req/s"
        }]
      },
      {
        "type": "stat",
        "title": "Error Rate",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
        "id": 2,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]}
          }
        },
        "targets": [{
          "expr": "sum(rate(order_requests_total{status=~\"5..\"}[1m])) / sum(rate(order_requests_total[1m]))",
          "legendFormat": "error %"
        }]
      },
      {
        "type": "stat",
        "title": "Active Orders",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
        "id": 3,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {"defaults": {"unit": "short"}},
        "targets": [{
          "expr": "sum(active_orders_count)",
          "legendFormat": "active"
        }]
      },
      {
        "type": "stat",
        "title": "Total Orders Created",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
        "id": 4,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {"defaults": {"unit": "short"}},
        "targets": [{
          "expr": "sum(orders_created_total{status=\"success\"})",
          "legendFormat": "success"
        }]
      },
      {
        "type": "timeseries",
        "title": "Order Request Rate — Success vs Errors",
        "gridPos": {"h": 7, "w": 12, "x": 0, "y": 5},
        "id": 5,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {"unit": "reqps"},
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "errors"},
              "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
            },
            {
              "matcher": {"id": "byName", "options": "success"},
              "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]
            }
          ]
        },
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [
          {
            "expr": "sum(rate(order_requests_total{status=~\"2..\"}[1m]))",
            "legendFormat": "success"
          },
          {
            "expr": "sum(rate(order_requests_total{status=~\"5..\"}[1m]))",
            "legendFormat": "errors"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Order Service Latency — p50 / p95 / p99",
        "gridPos": {"h": 7, "w": 12, "x": 12, "y": 5},
        "id": 6,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {"defaults": {"unit": "s"}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(order_request_duration_seconds_bucket[1m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(order_request_duration_seconds_bucket[1m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(order_request_duration_seconds_bucket[1m])) by (le))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "type": "row",
        "title": "Inventory Service",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 12},
        "collapsed": false,
        "id": 200
      },
      {
        "type": "stat",
        "title": "Request Rate",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 13},
        "id": 7,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background"
        },
        "fieldConfig": {"defaults": {"unit": "reqps"}},
        "targets": [{
          "expr": "sum(rate(inventory_requests_total[1m]))",
          "legendFormat": "req/s"
        }]
      },
      {
        "type": "stat",
        "title": "Stock Reduction Failures",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 13},
        "id": 8,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]}
          }
        },
        "targets": [{
          "expr": "sum(inventory_reduction_failures_total)",
          "legendFormat": "failures"
        }]
      },
      {
        "type": "bargauge",
        "title": "Current Stock Level per Product",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
        "id": 9,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "orientation": "horizontal",
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "displayMode": "gradient"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "max": 200,
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "green", "value": 30}
            ]}
          }
        },
        "targets": [{
          "expr": "inventory_stock_level",
          "legendFormat": "{{product_id}}"
        }]
      },
      {
        "type": "timeseries",
        "title": "Stock Level over Time",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 17},
        "id": 10,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {"defaults": {"unit": "short"}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{
          "expr": "inventory_stock_level",
          "legendFormat": "{{product_id}}"
        }]
      },
      {
        "type": "row",
        "title": "Notification Service",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
        "collapsed": false,
        "id": 300
      },
      {
        "type": "stat",
        "title": "Notifications Sent",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
        "id": 11,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value"
        },
        "fieldConfig": {"defaults": {"unit": "short"}},
        "targets": [{
          "expr": "sum(notifications_sent_total{status=\"success\"})",
          "legendFormat": "sent"
        }]
      },
      {
        "type": "stat",
        "title": "Failed Deliveries",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24},
        "id": 12,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]}
          }
        },
        "targets": [{
          "expr": "sum(notification_failed_deliveries_total)",
          "legendFormat": "failed"
        }]
      },
      {
        "type": "stat",
        "title": "Notification Queue Size",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 24},
        "id": 13,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]}
          }
        },
        "targets": [{
          "expr": "notification_queue_size",
          "legendFormat": "queue"
        }]
      },
      {
        "type": "stat",
        "title": "Delivery Success Rate",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 24},
        "id": 15,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "color": {"mode": "thresholds"},
            "thresholds": {"steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.90},
              {"color": "green", "value": 0.95}
            ]}
          }
        },
        "targets": [{
          "expr": "sum(rate(notifications_sent_total{status=\"success\"}[5m])) / sum(rate(notifications_sent_total[5m]))",
          "legendFormat": "success rate"
        }]
      },
      {
        "type": "timeseries",
        "title": "Notification Rate — Success vs Failed",
        "gridPos": {"h": 7, "w": 24, "x": 0, "y": 28},
        "id": 14,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {"unit": "reqps"},
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "failed"},
              "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
            },
            {
              "matcher": {"id": "byName", "options": "success"},
              "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]
            }
          ]
        },
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [
          {
            "expr": "sum(rate(notifications_sent_total{status=\"success\"}[1m]))",
            "legendFormat": "success"
          },
          {
            "expr": "sum(rate(notifications_sent_total{status=\"failed\"}[1m]))",
            "legendFormat": "failed"
          }
        ]
      }
    ],
    "time": {"from": "now-1h", "to": "now"}
  },
  "overwrite": true,
  "folderId": 0
}
